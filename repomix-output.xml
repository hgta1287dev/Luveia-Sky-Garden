local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CameraContext = require(ReplicatedStorage.Shared.Services.CameraService.CameraModule.Context.CameraContext)
local BaseCameraMode = require(script.Parent.BaseCameraMode)

local CameraOrbital = setmetatable({}, BaseCameraMode)
CameraOrbital.__index = CameraOrbital

-- * Lifecycle
function CameraOrbital.new()
	local self = setmetatable(BaseCameraMode.new(), CameraOrbital)
	return self
end

function CameraOrbital:Enter(context: CameraContext.CameraContext)
	BaseCameraMode.Enter(self, context)
	local states = context:GetModeStates()
	self._currentYaw = states.Orbit.TargetYaw
	self._currentPitch = states.Orbit.TargetPitch
	self._currentDistance = states.Orbit.TargetDistance
end

function CameraOrbital:Update(dt: number)
	local context = self.context :: CameraContext.CameraContext
	local states = context:GetModeStates()

	local lat = states.LookAtTarget

	local smooth = states.SmoothFactor
	local speed = states.Sensitivity
	local alpha = dt * speed * smooth

	self._currentYaw = math.lerp(self._currentYaw, states.Orbit.TargetYaw, alpha)
	self._currentPitch = math.lerp(self._currentPitch, states.Orbit.TargetPitch, alpha)
	self._currentDistance = math.lerp(self._currentDistance, states.Orbit.TargetDistance, alpha)

	local origin = ((lat and lat.Position) or Vector3.zero) + states.PivotOffset
	local orbitOffset = CFrame.Angles(0, math.rad(self._currentYaw), 0)
		* CFrame.Angles(math.rad(self._currentPitch), 0, 0)
		* Vector3.new(0, 0, self._currentDistance)
	local target = origin + orbitOffset

	return CFrame.lookAt(target, origin) * CFrame.new(states.CameraOffset)
end

return CameraOrbital
